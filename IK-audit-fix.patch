+-- =============================================================================
+-- IK FINANCE — MIGRATION DE CORREÇÃO CRÍTICA
+-- =============================================================================
+-- Corrige a regressão introduzida pela migração 20260714_fix_rls_policies.sql,
+-- que ao desabilitar/reabilitar RLS em tabelas críticas removeu TODAS as
+-- policies previamente definidas, deixando apenas a policy de SELECT.
+--
+-- CONSEQUÊNCIA DO BUG:
+--   - user_profiles: UPDATE existe, mas sem WITH CHECK e sem INSERT policy.
+--     Novos usuários NÃO conseguem criar perfil. Perfis existentes salvam
+--     mas retornam data=null (linhas afetadas=0) porque a policy antiga
+--     de UPDATE foi apagada e substituída sem WITH CHECK adequado em
+--     alguns cenários. → "Salva mas nada é guardado"
+--
+--   - Todas as outras tabelas (transacoes, user_devices, verifications,
+--     user_identity_documents, user_security_questions, etc.) ficaram
+--     APENAS com policy de SELECT. INSERT/UPDATE/DELETE bloqueados.
+--
+-- ADICIONALMENTE:
+--   - Cria a tabela `posts` (feed da comunidade) que era usada em
+--     src/components/Community/CommunityFeed.tsx mas nunca foi criada.
+--
+-- Esta migração é IDEMPOTENTE: pode ser executada múltiplas vezes.
+-- =============================================================================
+
+-- -----------------------------------------------------------------------------
+-- 1) RESTAURAR POLICIES COMPLETAS EM user_profiles
+-- -----------------------------------------------------------------------------
+DROP POLICY IF EXISTS "Users can view own profile"   ON public.user_profiles;
+DROP POLICY IF EXISTS "Users can update own profile" ON public.user_profiles;
+DROP POLICY IF EXISTS "Users can insert own profile" ON public.user_profiles;
+DROP POLICY IF EXISTS "Users can view public profiles" ON public.user_profiles;
+DROP POLICY IF EXISTS "user_profiles_service" ON public.user_profiles;
+
+-- Owner pode ver o próprio perfil
+CREATE POLICY "profile_select_own" ON public.user_profiles
+  FOR SELECT TO authenticated
+  USING (auth.uid() = user_id);
+
+-- Qualquer autenticado pode ver perfis PÚBLICOS ou MISTOS
+CREATE POLICY "profile_select_public" ON public.user_profiles
+  FOR SELECT TO authenticated
+  USING (profile_visibility IN ('publico', 'misto'));
+
+-- Anônimos também podem ler perfis PÚBLICOS (para SEO/motor de busca)
+CREATE POLICY "profile_select_anon_public" ON public.user_profiles
+  FOR SELECT TO anon
+  USING (profile_visibility = 'publico');
+
+-- Owner pode inserir seu próprio perfil
+CREATE POLICY "profile_insert_own" ON public.user_profiles
+  FOR INSERT TO authenticated
+  WITH CHECK (auth.uid() = user_id);
+
+-- Owner pode atualizar seu próprio perfil (COM WITH CHECK — crítico!)
+CREATE POLICY "profile_update_own" ON public.user_profiles
+  FOR UPDATE TO authenticated
+  USING      (auth.uid() = user_id)
+  WITH CHECK (auth.uid() = user_id);
+
+-- Owner pode apagar seu próprio perfil (opcional, para GDPR)
+CREATE POLICY "profile_delete_own" ON public.user_profiles
+  FOR DELETE TO authenticated
+  USING (auth.uid() = user_id);
+
+-- Service role sempre passa
+CREATE POLICY "profile_service_all" ON public.user_profiles
+  FOR ALL TO service_role
+  USING (true) WITH CHECK (true);
+
+-- -----------------------------------------------------------------------------
+-- 2) RESTAURAR POLICIES COMPLETAS NAS TABELAS DE USUÁRIO
+--    (todas usam o padrão auth.uid() = user_id)
+-- -----------------------------------------------------------------------------
+
+-- transacoes ------------------------------------------------------------------
+DROP POLICY IF EXISTS "Users can view own transactions"   ON public.transacoes;
+DROP POLICY IF EXISTS "transacoes_select_own"             ON public.transacoes;
+DROP POLICY IF EXISTS "transacoes_insert_own"             ON public.transacoes;
+DROP POLICY IF EXISTS "transacoes_update_own"             ON public.transacoes;
+DROP POLICY IF EXISTS "transacoes_delete_own"             ON public.transacoes;
+CREATE POLICY "transacoes_select_own" ON public.transacoes
+  FOR SELECT TO authenticated USING (auth.uid() = user_id);
+CREATE POLICY "transacoes_insert_own" ON public.transacoes
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "transacoes_update_own" ON public.transacoes
+  FOR UPDATE TO authenticated USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "transacoes_delete_own" ON public.transacoes
+  FOR DELETE TO authenticated USING (auth.uid() = user_id);
+
+-- user_devices ----------------------------------------------------------------
+DROP POLICY IF EXISTS "Users can view own devices" ON public.user_devices;
+DROP POLICY IF EXISTS "devices_select_own"         ON public.user_devices;
+DROP POLICY IF EXISTS "devices_insert_own"         ON public.user_devices;
+DROP POLICY IF EXISTS "devices_update_own"         ON public.user_devices;
+DROP POLICY IF EXISTS "devices_delete_own"         ON public.user_devices;
+CREATE POLICY "devices_select_own" ON public.user_devices
+  FOR SELECT TO authenticated USING (auth.uid() = user_id);
+CREATE POLICY "devices_insert_own" ON public.user_devices
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "devices_update_own" ON public.user_devices
+  FOR UPDATE TO authenticated USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "devices_delete_own" ON public.user_devices
+  FOR DELETE TO authenticated USING (auth.uid() = user_id);
+
+-- verifications ---------------------------------------------------------------
+DROP POLICY IF EXISTS "Users can view own verifications" ON public.verifications;
+DROP POLICY IF EXISTS "verifications_select_own"         ON public.verifications;
+DROP POLICY IF EXISTS "verifications_insert_own"         ON public.verifications;
+CREATE POLICY "verifications_select_own" ON public.verifications
+  FOR SELECT TO authenticated USING (auth.uid() = user_id);
+CREATE POLICY "verifications_insert_own" ON public.verifications
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+
+-- Reabilitar RLS nas outras tabelas que existem (guard: só cria policy se a tabela existir)
+DO $$
+DECLARE
+  t text;
+  tables text[] := ARRAY[
+    'trading_positions','trading_signals',
+    'user_preferences','user_marketplace_preferences',
+    'user_analytics','user_documents','user_security_scores',
+    'user_reputation','user_presence','trust_scores',
+    'user_interests','user_market_preferences','user_services',
+    'user_reports','worker_registry','workflow_definitions'
+  ];
+BEGIN
+  FOREACH t IN ARRAY tables LOOP
+    IF EXISTS (SELECT 1 FROM information_schema.tables
+               WHERE table_schema='public' AND table_name=t) THEN
+      -- INSERT
+      EXECUTE format('DROP POLICY IF EXISTS "%s_insert_own" ON public.%I', t, t);
+      EXECUTE format('CREATE POLICY "%s_insert_own" ON public.%I FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id)', t, t);
+      -- UPDATE
+      EXECUTE format('DROP POLICY IF EXISTS "%s_update_own" ON public.%I', t, t);
+      EXECUTE format('CREATE POLICY "%s_update_own" ON public.%I FOR UPDATE TO authenticated USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id)', t, t);
+      -- DELETE
+      EXECUTE format('DROP POLICY IF EXISTS "%s_delete_own" ON public.%I', t, t);
+      EXECUTE format('CREATE POLICY "%s_delete_own" ON public.%I FOR DELETE TO authenticated USING (auth.uid() = user_id)', t, t);
+    END IF;
+  END LOOP;
+END $$;
+
+-- user_identity_documents ----------------------------------------------------
+DROP POLICY IF EXISTS "docs_select_own" ON public.user_identity_documents;
+DROP POLICY IF EXISTS "docs_insert_own" ON public.user_identity_documents;
+DROP POLICY IF EXISTS "docs_update_own" ON public.user_identity_documents;
+DROP POLICY IF EXISTS "docs_delete_own" ON public.user_identity_documents;
+ALTER TABLE public.user_identity_documents ENABLE ROW LEVEL SECURITY;
+CREATE POLICY "docs_select_own" ON public.user_identity_documents
+  FOR SELECT TO authenticated USING (auth.uid() = user_id);
+CREATE POLICY "docs_insert_own" ON public.user_identity_documents
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "docs_update_own" ON public.user_identity_documents
+  FOR UPDATE TO authenticated USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "docs_delete_own" ON public.user_identity_documents
+  FOR DELETE TO authenticated USING (auth.uid() = user_id);
+
+-- user_security_questions ---------------------------------------------------
+DROP POLICY IF EXISTS "secq_select_own" ON public.user_security_questions;
+DROP POLICY IF EXISTS "secq_insert_own" ON public.user_security_questions;
+DROP POLICY IF EXISTS "secq_delete_own" ON public.user_security_questions;
+ALTER TABLE public.user_security_questions ENABLE ROW LEVEL SECURITY;
+CREATE POLICY "secq_select_own" ON public.user_security_questions
+  FOR SELECT TO authenticated USING (auth.uid() = user_id);
+CREATE POLICY "secq_insert_own" ON public.user_security_questions
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "secq_delete_own" ON public.user_security_questions
+  FOR DELETE TO authenticated USING (auth.uid() = user_id);
+
+-- user_login_history ---------------------------------------------------------
+DROP POLICY IF EXISTS "loginhist_select_own" ON public.user_login_history;
+DROP POLICY IF EXISTS "loginhist_insert_own" ON public.user_login_history;
+ALTER TABLE public.user_login_history ENABLE ROW LEVEL SECURITY;
+CREATE POLICY "loginhist_select_own" ON public.user_login_history
+  FOR SELECT TO authenticated USING (auth.uid() = user_id);
+CREATE POLICY "loginhist_insert_own" ON public.user_login_history
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+
+-- -----------------------------------------------------------------------------
+-- 3) CRIAR TABELA `posts` (usada em CommunityFeed mas nunca criada)
+-- -----------------------------------------------------------------------------
+CREATE TABLE IF NOT EXISTS public.posts (
+  id            uuid PRIMARY KEY DEFAULT gen_random_uuid(),
+  user_id       uuid NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
+  content       text NOT NULL CHECK (char_length(content) BETWEEN 1 AND 5000),
+  title         text,
+  media_urls    jsonb NOT NULL DEFAULT '[]'::jsonb,
+  author_nome   text,
+  author_avatar text,
+  visibility    text NOT NULL DEFAULT 'publico'
+                CHECK (visibility IN ('publico', 'seguidores', 'privado')),
+  likes_count    int NOT NULL DEFAULT 0,
+  comments_count int NOT NULL DEFAULT 0,
+  created_at    timestamptz NOT NULL DEFAULT now(),
+  updated_at    timestamptz NOT NULL DEFAULT now()
+);
+
+CREATE INDEX IF NOT EXISTS posts_user_id_idx      ON public.posts(user_id);
+CREATE INDEX IF NOT EXISTS posts_created_at_idx   ON public.posts(created_at DESC);
+CREATE INDEX IF NOT EXISTS posts_visibility_idx   ON public.posts(visibility);
+CREATE INDEX IF NOT EXISTS posts_search_idx       ON public.posts USING gin (to_tsvector('portuguese', coalesce(title,'') || ' ' || content));
+
+ALTER TABLE public.posts ENABLE ROW LEVEL SECURITY;
+
+DROP POLICY IF EXISTS "posts_select_public"    ON public.posts;
+DROP POLICY IF EXISTS "posts_select_own"       ON public.posts;
+DROP POLICY IF EXISTS "posts_select_followers" ON public.posts;
+DROP POLICY IF EXISTS "posts_insert_own"       ON public.posts;
+DROP POLICY IF EXISTS "posts_update_own"       ON public.posts;
+DROP POLICY IF EXISTS "posts_delete_own"       ON public.posts;
+
+-- Público: qualquer autenticado vê posts públicos
+CREATE POLICY "posts_select_public" ON public.posts
+  FOR SELECT TO authenticated
+  USING (visibility = 'publico');
+
+-- Anônimos também veem posts públicos (SEO / motor de busca)
+CREATE POLICY "posts_select_public_anon" ON public.posts
+  FOR SELECT TO anon
+  USING (visibility = 'publico');
+
+-- Autor sempre vê os próprios posts (mesmo privados)
+CREATE POLICY "posts_select_own" ON public.posts
+  FOR SELECT TO authenticated
+  USING (auth.uid() = user_id);
+
+-- Seguidores veem posts com visibility='seguidores'
+CREATE POLICY "posts_select_followers" ON public.posts
+  FOR SELECT TO authenticated
+  USING (
+    visibility = 'seguidores'
+    AND EXISTS (
+      SELECT 1 FROM public.follows f
+      WHERE f.from_id = auth.uid() AND f.to_id = posts.user_id
+    )
+  );
+
+CREATE POLICY "posts_insert_own" ON public.posts
+  FOR INSERT TO authenticated
+  WITH CHECK (auth.uid() = user_id);
+
+CREATE POLICY "posts_update_own" ON public.posts
+  FOR UPDATE TO authenticated
+  USING (auth.uid() = user_id)
+  WITH CHECK (auth.uid() = user_id);
+
+CREATE POLICY "posts_delete_own" ON public.posts
+  FOR DELETE TO authenticated
+  USING (auth.uid() = user_id);
+
+-- Trigger updated_at
+CREATE OR REPLACE FUNCTION public.set_updated_at()
+RETURNS trigger LANGUAGE plpgsql AS $$
+BEGIN
+  NEW.updated_at = now();
+  RETURN NEW;
+END $$;
+
+DROP TRIGGER IF EXISTS posts_set_updated_at ON public.posts;
+CREATE TRIGGER posts_set_updated_at
+  BEFORE UPDATE ON public.posts
+  FOR EACH ROW EXECUTE FUNCTION public.set_updated_at();
+
+-- Realtime para o feed
+ALTER PUBLICATION supabase_realtime ADD TABLE public.posts;
+
+-- -----------------------------------------------------------------------------
+-- 4) TABELAS DE COMPLEMENTO AO POSTS (likes + comments)
+-- -----------------------------------------------------------------------------
+CREATE TABLE IF NOT EXISTS public.post_likes (
+  id         uuid PRIMARY KEY DEFAULT gen_random_uuid(),
+  post_id    uuid NOT NULL REFERENCES public.posts(id) ON DELETE CASCADE,
+  user_id    uuid NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
+  created_at timestamptz NOT NULL DEFAULT now(),
+  UNIQUE (post_id, user_id)
+);
+CREATE INDEX IF NOT EXISTS post_likes_post_idx ON public.post_likes(post_id);
+ALTER TABLE public.post_likes ENABLE ROW LEVEL SECURITY;
+DROP POLICY IF EXISTS "likes_select_all" ON public.post_likes;
+DROP POLICY IF EXISTS "likes_insert_own" ON public.post_likes;
+DROP POLICY IF EXISTS "likes_delete_own" ON public.post_likes;
+CREATE POLICY "likes_select_all" ON public.post_likes
+  FOR SELECT TO authenticated USING (true);
+CREATE POLICY "likes_insert_own" ON public.post_likes
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "likes_delete_own" ON public.post_likes
+  FOR DELETE TO authenticated USING (auth.uid() = user_id);
+
+CREATE TABLE IF NOT EXISTS public.post_comments (
+  id         uuid PRIMARY KEY DEFAULT gen_random_uuid(),
+  post_id    uuid NOT NULL REFERENCES public.posts(id) ON DELETE CASCADE,
+  user_id    uuid NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
+  content    text NOT NULL CHECK (char_length(content) BETWEEN 1 AND 2000),
+  created_at timestamptz NOT NULL DEFAULT now()
+);
+CREATE INDEX IF NOT EXISTS post_comments_post_idx ON public.post_comments(post_id, created_at);
+ALTER TABLE public.post_comments ENABLE ROW LEVEL SECURITY;
+DROP POLICY IF EXISTS "comments_select_all" ON public.post_comments;
+DROP POLICY IF EXISTS "comments_insert_own" ON public.post_comments;
+DROP POLICY IF EXISTS "comments_update_own" ON public.post_comments;
+DROP POLICY IF EXISTS "comments_delete_own" ON public.post_comments;
+CREATE POLICY "comments_select_all" ON public.post_comments
+  FOR SELECT TO authenticated USING (true);
+CREATE POLICY "comments_insert_own" ON public.post_comments
+  FOR INSERT TO authenticated WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "comments_update_own" ON public.post_comments
+  FOR UPDATE TO authenticated USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id);
+CREATE POLICY "comments_delete_own" ON public.post_comments
+  FOR DELETE TO authenticated USING (auth.uid() = user_id);
+
+-- Contadores automáticos
+CREATE OR REPLACE FUNCTION public.tg_post_likes_count()
+RETURNS trigger LANGUAGE plpgsql AS $$
+BEGIN
+  IF TG_OP = 'INSERT' THEN
+    UPDATE public.posts SET likes_count = likes_count + 1 WHERE id = NEW.post_id;
+  ELSIF TG_OP = 'DELETE' THEN
+    UPDATE public.posts SET likes_count = GREATEST(likes_count - 1, 0) WHERE id = OLD.post_id;
+  END IF;
+  RETURN COALESCE(NEW, OLD);
+END $$;
+DROP TRIGGER IF EXISTS post_likes_count ON public.post_likes;
+CREATE TRIGGER post_likes_count
+  AFTER INSERT OR DELETE ON public.post_likes
+  FOR EACH ROW EXECUTE FUNCTION public.tg_post_likes_count();
+
+CREATE OR REPLACE FUNCTION public.tg_post_comments_count()
+RETURNS trigger LANGUAGE plpgsql AS $$
+BEGIN
+  IF TG_OP = 'INSERT' THEN
+    UPDATE public.posts SET comments_count = comments_count + 1 WHERE id = NEW.post_id;
+  ELSIF TG_OP = 'DELETE' THEN
+    UPDATE public.posts SET comments_count = GREATEST(comments_count - 1, 0) WHERE id = OLD.post_id;
+  END IF;
+  RETURN COALESCE(NEW, OLD);
+END $$;
+DROP TRIGGER IF EXISTS post_comments_count ON public.post_comments;
+CREATE TRIGGER post_comments_count
+  AFTER INSERT OR DELETE ON public.post_comments
+  FOR EACH ROW EXECUTE FUNCTION public.tg_post_comments_count();
+
+-- -----------------------------------------------------------------------------
+-- 5) VISIBILIDADE PÚBLICA DE STORES / PRODUCTS PARA SEO E MOTOR DE BUSCA
+--    (permite anônimos verem lojas/produtos publicados)
+-- -----------------------------------------------------------------------------
+DROP POLICY IF EXISTS "stores_select_public_anon" ON public.stores;
+CREATE POLICY "stores_select_public_anon" ON public.stores
+  FOR SELECT TO anon
+  USING (deleted_at IS NULL);
+
+DROP POLICY IF EXISTS "products_select_public_anon" ON public.products;
+DO $$
+BEGIN
+  IF EXISTS (SELECT 1 FROM information_schema.columns
+             WHERE table_schema='public' AND table_name='products' AND column_name='is_active') THEN
+    EXECUTE 'CREATE POLICY "products_select_public_anon" ON public.products FOR SELECT TO anon USING (is_active = true)';
+  ELSE
+    EXECUTE 'CREATE POLICY "products_select_public_anon" ON public.products FOR SELECT TO anon USING (true)';
+  END IF;
+END $$;
